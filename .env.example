# ==============================================================================
# JARVIS CORE - ARQUIVO MESTRE DE VARIÁVEIS DE AMBIENTE
# ==============================================================================
# Renomeie este arquivo para .env (ou copie-o) para ser lido pelo sistema.
# ==============================================================================

# ---------------------------------------------------------
# SISTEMA E BANCO DE DADOS
# ---------------------------------------------------------
# URL do Servidor Local NodeJS (Frontend Vite)
VITE_SERVER_URL="http://localhost:3000"

# URL do Banco de Dados SQLite (Usado pelo Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Caminho Físico na sua máquina para o Cérebro do JARVIS (Obsidian)
OBSIDIAN_VAULT_PATH="C:\jarvis-vault"

# ---------------------------------------------------------
# AUTENTICAÇÃO E SEGURANÇA (OBRIGATÓRIOS PARA ACESSO EXTERNO)
# ---------------------------------------------------------
# Client ID do Google Cloud para Autenticação OAuth
GOOGLE_CLIENT_ID="108258960134-pe7s1qcv8219eb3r8g8n0j98panblktv.apps.googleusercontent.com"

# Chave API de segurança criada por você (para autenticar apps de terceiros e Cloudflare)
JARVIS_API_KEY="minha_api_key_segura"

# ---------------------------------------------------------
# INTELIGÊNCIA ARTIFICIAL (LLMs)
# ---------------------------------------------------------
# Chave da Groq (Llama 3/Mixtral) para IA ultrarrápida sem depender de hardware local
GROQ_API_KEY="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"

# ---------------------------------------------------------
# AUTOMAÇÃO DE HARDWARE (HOME ASSISTANT)
# ---------------------------------------------------------
# IP local da sua central do Home Assistant (Ex: 192.168.15.10)
HOME_ASSISTANT_IP="192.168.15.10"

# Token de Longa Duração gerado no Home Assistant
HOME_ASSISTANT_TOKEN=""

# ---------------------------------------------------------
# VOZ E NOTIFICAÇÕES (MÓDULOS EXTRAS)
# ---------------------------------------------------------
# Token do Bot criado no @BotFather do Telegram para receber notificações no celular
TELEGRAM_TOKEN=""
