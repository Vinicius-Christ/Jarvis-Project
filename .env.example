# DATABASE CONFIGURATION
# Caminho para o banco de dados SQLite local
DATABASE_URL="file:./prisma/dev.db"

# SEGURANÇA E AUTENTICAÇÃO
# Secret para assinatura de tokens JWT (Defina uma chave criptograficamente forte em produção)
JWT_SECRET=defina_uma_jwt_secret_segura_de_pelo_menos_32_caracteres_aqui

# CHAVES DE APIS EXTERNAS
# Chave da API do Groq para inferência LPU
GROQ_API_KEY=sua_chave_groq_aqui


# HOME ASSISTANT / AUTOMAÇÃO RESIDENCIAL
# URL local do Home Assistant
HA_URL=http://localhost:8123
# Token de acesso de longa duração do Home Assistant (Long-Lived Access Token)
HA_TOKEN=seu_token_home_assistant_aqui

# MEMÓRIA OBSIDIAN
# Caminho absoluto da pasta do cofre no Windows (Vault)
OBSIDIAN_VAULT_PATH=C:/jarvis-vault

# CONFIGURAÇÕES DO SERVIDOR
# URL externa do servidor (ex: túnel do Cloudflare ou IP na rede local)
VITE_SERVER_URL=http://localhost:3000
NODE_ENV=development
