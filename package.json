  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite",
    "dev:desktop": "concurrently \"tsx server.ts\" \"vite\" \"wait-on http://localhost:5173 && tauri dev\"",
    "tauri": "tauri",
    "build": "npm run clean && vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "clean": "rm -rf dist server.js release",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
