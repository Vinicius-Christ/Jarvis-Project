{
  "name": "jarvis-system-suite",
  "private": true,
  "version": "1.0.0",
  "description": "Sistema Jarvis Residencial e IA",
  "author": "Vinícius",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite",
    "dev:desktop": "concurrently \"tsx server.ts\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run clean && vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "clean": "rimraf dist server.js release",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "desktop": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "build": {
    "appId": "com.jarvis.desktop.suite",
    "productName": "JARVIS Suite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "electron-preload.cjs",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "asar": true,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dompurify": "^3.4.11",
    "express": "^4.21.2",
    "helmet": "^7.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "motion": "^12.23.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "systeminformation": "^5.31.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10",
    "@vitejs/plugin-react": "^5.0.4",
    "@tailwindcss/vite": "^4.1.14",
    "lucide-react": "^0.546.0",
    "recharts": "^3.8.1"
  }
}