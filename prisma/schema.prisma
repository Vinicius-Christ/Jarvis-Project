generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Finance {
  id          Int      @id @default(autoincrement())
  value       Float
  category    String
  description String
  type        String
  date        DateTime @default(now())
}

model Agenda {
  id       Int      @id @default(autoincrement())
  title    String
  datetime DateTime
  category String
  notes    String?
}

model Goal {
  id     Int    @id @default(autoincrement())
  limit  Float
  reason String
}

model Conversation {
  id     Int      @id @default(autoincrement())
  sender String
  text   String
  time   DateTime @default(now())
}

model HomeAssistantState {
  id            Int    @id @default(autoincrement())
  ip            String @default("")
  token         String @default("")
  ambientPreset String @default("Normal")
  lights        String @default("{}")
  ac            String @default("{}")
  devices       String @default("[]")
  wsStatus      String @default("disconnected")
  hiddenDevices String @default("[]")
  modesConfig   String @default("{}")
}

model AppConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     String @default("admin")
}
