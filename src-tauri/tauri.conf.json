{
    "build": {
        "beforeDevCommand": "",
        "beforeBuildCommand": "npm run build:frontend",
        "devPath": "http://localhost:5173",
        "distDir": "../dist"
    },
    "package": {
        "productName": "Jarvis Tauri Overlay",
        "version": "1.0.0"
    },
    "tauri": {
        "allowlist": {
            "all": true,
            "globalShortcut": {
                "all": true
            },
            "window": {
                "all": true,
                "create": true
            }
        },
        "bundle": {
            "active": true,
            "identifier": "com.jarvis.tauri",
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ]
        },
        "windows": [
            {
                "fullscreen": false,
                "height": 650,
                "width": 1000,
                "minHeight": 400,
                "minWidth": 600,
                "resizable": true,
                "maximizable": true,
                "transparent": false,
                "decorations": true,
                "alwaysOnTop": false,
                "label": "main",
                "title": "Jarvis",
                "visible": true,
                "center": true
            }
        ]
    }
}